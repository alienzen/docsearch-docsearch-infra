# ── DocSearch — Variables d'environnement ────────────────────
# Mis à jour le 29/06/2026

# ── Chemins ───────────────────────────────────────────────────
DOCS_PATH=/documents

# ── Elasticsearch 9.4.2 ───────────────────────────────────────
ES_HOST=http://es01:9200
ES_INDEX=documents

# ── Kafka ─────────────────────────────────────────────────────
KAFKA_BOOTSTRAP=kafka:9092
KAFKA_TOPIC=documents-to-index

# ── Tika 3.3.1.0 ────────────────────────────────────────────────
TIKA_SERVERS=http://tika1:9998,http://tika2:9998,http://tika3:9998,http://tika4:9998

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── Workers ───────────────────────────────────────────────────
WORKER_BATCH_SIZE=200
WORKER_REPLICAS=8

# ── JVM Elasticsearch ─────────────────────────────────────────
ES_JAVA_OPTS=-Xms4g -Xmx4g

# ── ACL / LDAP ────────────────────────────────────────────────
# Mettre LDAP_ENABLED=true pour activer la résolution des groupes AD
LDAP_ENABLED=false
LDAP_HOST=ldap://dc01.domaine.gouv.fr
LDAP_BASE=dc=domaine,dc=gouv,dc=fr
LDAP_BINDDN=cn=svc-docsearch,ou=services,dc=domaine,dc=gouv,dc=fr
LDAP_PASS=changeme

# ── SSO (en-tête injecté par Nginx après validation SSO) ──────
# En dev : DEV_USER permet de simuler un utilisateur sans SSO
# En prod : laisser vide — l'identité vient du header X-User (Nginx/SSO)
DEV_USER=

# ── Permissions volumes ───────────────────────────────────────
# UID de l'utilisateur propriétaire de DOCS_PATH sur l'hôte.
# Récupérer avec : id -u
# Doit correspondre à l'UID du propriétaire de /data sur la VM.
DOCKER_UID=1000

# ── Watcher ───────────────────────────────────────────────────
# Intervalle de polling en secondes (défaut 10).
# inotify ne fonctionne pas sur les partages CIFS/NFS — le watcher
# utilise le mode polling qui est compatible avec tous les montages.
# Réduire pour une détection plus rapide (au prix de plus d'I/O).
WATCHER_POLL_INTERVAL=10
