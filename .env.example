# ── DocSearch — Variables d'environnement ────────────────────
# Mis à jour le 08/07/2026 — multi-source

# ── Chemins (multi-source) ───────────────────────────────────
# SOURCES_ROOT  : dossier PARENT réel sur l'HÔTE, contenant un
#                 sous-dossier par source à indexer (ex:
#                 SOURCES_ROOT/documents, SOURCES_ROOT/finance, ...).
# SOURCES_MOUNT : point de montage correspondant À L'INTÉRIEUR des
#                 conteneurs (dérivé de la même variable que le volume
#                 Docker, ils ne peuvent donc jamais diverger).
#
# Un bind-mount Docker est fixé à la création du conteneur : on ne peut
# pas en ajouter un nouveau sans recréer les conteneurs. C'est pourquoi
# TOUTES les sources vivent sous CE SEUL point de montage parent —
# ajouter une source ne nécessite ensuite qu'un sous-dossier de
# SOURCES_ROOT + un enregistrement dynamique (./manage.sh add-file-source),
# jamais de toucher à ce fichier ni de redémarrer un conteneur.
SOURCES_ROOT=/data/docsearch-sources
SOURCES_MOUNT=/sources

# ── Migration depuis une installation mono-source (DOCS_PATH) ──
# Si vous mettez à jour une installation existante : déplacez le
# contenu de l'ancien DOCS_PATH vers $SOURCES_ROOT/documents (ou pointez
# SOURCES_ROOT directement sur le parent de ce dossier s'il est déjà
# organisé ainsi), puis lancez './manage.sh restart' UNE FOIS. Après
# cette migration unique, toute nouvelle source s'ajoute à chaud, sans
# redémarrage (voir manage.sh add-file-source / list-file-sources / remove-file-source).
# DEFAULT_SOURCE_SUBFOLDER : sous-dossier de SOURCES_ROOT utilisé par la
# source par défaut ("documents") — ne change quasiment jamais.
DEFAULT_SOURCE_SUBFOLDER=documents

# ── Elasticsearch 9.4.2 ───────────────────────────────────────
ES_HOST=http://es01:9200
# ES_INDEX : index de la source par défaut ("documents"). Les sources
# ajoutées ensuite ont chacune leur propre index, déclaré au moment de
# ./manage.sh add-file-source — pas ici.
ES_INDEX=documents
# ES_SEARCH_ALIAS : alias Elasticsearch partagé par TOUS les index de
# toutes les sources — c'est lui que docsearch-api interroge par défaut
# pour une recherche fédérée. Rarement besoin d'y toucher.
ES_SEARCH_ALIAS=docsearch-all

# ── Kafka ─────────────────────────────────────────────────────
KAFKA_BOOTSTRAP=kafka:9092
KAFKA_TOPIC=documents-to-index

# ── Tika 3.3.1.0 ────────────────────────────────────────────────
TIKA_SERVERS=http://tika1:9998,http://tika2:9998,http://tika3:9998,http://tika4:9998

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── Workers ───────────────────────────────────────────────────
WORKER_BATCH_SIZE=200
WORKER_REPLICAS=8

# ── JVM Elasticsearch ─────────────────────────────────────────
ES_JAVA_OPTS=-Xms4g -Xmx4g

# ── ACL / LDAP ────────────────────────────────────────────────
# Mettre LDAP_ENABLED=true pour activer la résolution des groupes AD
LDAP_ENABLED=false
LDAP_HOST=ldap://dc01.domaine.gouv.fr
LDAP_BASE=dc=domaine,dc=gouv,dc=fr
LDAP_BINDDN=cn=svc-docsearch,ou=services,dc=domaine,dc=gouv,dc=fr
LDAP_PASS=changeme

# ── Panneau d'administration (/admin) ────────────────────────
# Groupe LDAP/AD dont les membres ont accès au panneau d'administration
# (configuration, purge, déclenchement de scan, état des composants).
# Nécessite LDAP_ENABLED=true. Laisser vide désactive complètement
# l'accès admin (refus explicite plutôt qu'un défaut permissif).
ADMIN_GROUP=docsearch-admins

# ⚠️  DANGER — TESTS LOCAUX UNIQUEMENT, JAMAIS EN PRODUCTION.
# ADMIN_AUTH_DISABLED=true contourne TOUT contrôle d'accès sur /admin
# (authentification ET groupe) — n'importe qui peut alors modifier la
# configuration, purger l'index ou déclencher des scans sans la
# moindre vérification. Utile uniquement pour tester le panneau
# d'administration sans SSO/LDAP configurés. Retirer cette ligne (ou
# remettre "false") avant tout déploiement réel.
ADMIN_AUTH_DISABLED=false

# ── SSO (en-tête injecté par Nginx après validation SSO) ──────
# En dev : DEV_USER permet de simuler un utilisateur sans SSO
# En prod : laisser vide — l'identité vient du header X-User (Nginx/SSO)
DEV_USER=

# ── Permissions volumes ───────────────────────────────────────
# UID de l'utilisateur propriétaire de SOURCES_ROOT sur l'hôte.
# Récupérer avec : id -u
# Doit correspondre à l'UID du propriétaire de /data sur la VM.
DOCKER_UID=1000

# ── Watcher ───────────────────────────────────────────────────
# Intervalle de polling en secondes (défaut 10).
# inotify ne fonctionne pas sur les partages CIFS/NFS — le watcher
# utilise le mode polling qui est compatible avec tous les montages.
# Réduire pour une détection plus rapide (au prix de plus d'I/O).
WATCHER_POLL_INTERVAL=10

# ── Connecteur SQL (sql-worker, indexation PostgreSQL/MySQL) ──
# Voir ./manage.sh add-sql-source / list-sql-sources / remove-sql-source
# / run-sql-source. SQL_SOURCES_CACHE_TTL : délai avant qu'un ajout/retrait
# de source soit pris en compte par sql-worker déjà démarré (défaut 10s).
SQL_SOURCES_CACHE_TTL=10
# Nombre de sources SQL traitées en parallèle (une requête longue sur une
# source ne doit pas retarder le polling des autres).
SQL_WORKER_MAX_PARALLEL=4

# ⚠️  SÉCURITÉ — chaque source SQL référence (connection_ref) le NOM
# d'une variable d'environnement OU d'un DSN enregistré depuis le panneau
# d'administration (voir bloc DSN_ENCRYPTION_KEY plus bas) — jamais le DSN
# lui-même. Aucune des deux méthodes n'est dépréciée : la variable
# d'environnement reste TOUJOURS prioritaire si elle existe pour le même
# nom, l'admin ne sert que de repli. Méthode 1 (ci-dessous, historique) :
# définir une variable ici, avec le nom choisi comme connection_ref lors de
# add-sql-source :
#   CLIENTS_DB_DSN=postgresql+psycopg2://user:motdepasse@host:5432/dbname
#   FACTURES_DB_DSN=mysql+pymysql://user:motdepasse@host:3306/dbname
# Utiliser de préférence un compte SQL en LECTURE SEULE, restreint à la
# ou aux tables interrogées.

# ── DSN dynamiques (panneau d'administration, méthode 2) ──────
# Alternative à la méthode 1 ci-dessus : un administrateur peut enregistrer
# un DSN depuis le panneau web (Sources SQL > DSN chiffrés, POST
# /admin/sql-dsns) SANS toucher à ce fichier ni recréer aucun conteneur. Le
# DSN est alors chiffré (Fernet, symétrique) avant d'être stocké dans
# Redis — jamais en clair, jamais réexposé par l'API après enregistrement
# (seul un indice schéma+hôte reste consultable). Nécessite DSN_ENCRYPTION_KEY,
# IDENTIQUE sur docsearch-api (qui chiffre à l'écriture) ET sur
# sql-worker/indexer-init côté docsearch-ingestion (qui déchiffrent pour se
# connecter réellement) — sans cette clé, /admin/sql-dsns refuse les
# écritures (503) mais le reste de DocSearch (y compris la méthode 1
# ci-dessus) continue de fonctionner normalement.
#
# Générer une clé :
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# Puis :
DSN_ENCRYPTION_KEY=

# Délai (secondes) avant qu'un ajout/retrait de DSN dynamique soit pris en
# compte par sql-worker déjà démarré (même principe que SQL_SOURCES_CACHE_TTL).
SQL_DSN_REGISTRY_CACHE_TTL=10
