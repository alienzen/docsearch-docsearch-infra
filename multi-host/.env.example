# ─────────────────────────────────────────────────────────────
#  DocSearch — Cluster multi-machines (8 serveurs)
#  Copier ce fichier en ".env" dans ce dossier, sur les 8 machines.
#  Contenu IDENTIQUE partout (mêmes IP vues par tous les rôles) —
#  seule la commande de lancement diffère par machine (voir README.md).
# ─────────────────────────────────────────────────────────────

# ── Adresses IP des 8 machines (LAN dédié au cluster) ────────
ES_DATA1_IP=192.168.10.11
ES_DATA2_IP=192.168.10.12
ES_VOTING_IP=192.168.10.13
KAFKA_IP=192.168.10.14
FRONTEND_IP=192.168.10.15
INGEST1_IP=192.168.10.16
INGEST2_IP=192.168.10.17
INGEST3_IP=192.168.10.18

# ── Elasticsearch ─────────────────────────────────────────────
# 16 Go de RAM par machine ES → heap à 7g (règle des 50%, marge
# laissée au cache page OS, critique pour les perfs de recherche).
ES_JAVA_OPTS_DATA=-Xms7g -Xmx7g
# Chemin sur l'HÔTE où est monté le SSD 4 To (es-data-1/2 uniquement).
ES_DATA_HOST_PATH=/data/es

# ── Sources documentaires (voir sources_config.py) ───────────
SOURCES_ROOT=/data/docsearch-sources
SOURCES_MOUNT=/sources
DEFAULT_SOURCE_SUBFOLDER=documents
ES_INDEX=documents
ES_SEARCH_ALIAS=docsearch-all

# ── Kafka ─────────────────────────────────────────────────────
KAFKA_TOPIC=documents-to-index
KAFKA_NUM_PARTITIONS=16

# ── Redis (colocalisé sur la machine "frontend") ─────────────
REDIS_PORT=6379

# ── Ingestion ─────────────────────────────────────────────────
# Nombre de workers PAR machine d'ingestion (3 machines) — ajuster
# après le pilote de dimensionnement. 3/machine = 9 workers au total,
# proche de la recommandation historique (12) pour 4M docs.
WORKERS_PER_INGEST_NODE=3

# ── ACL / LDAP ────────────────────────────────────────────────
LDAP_ENABLED=false
LDAP_HOST=ldap://dc01.domaine.gouv.fr
LDAP_BASE=dc=domaine,dc=gouv,dc=fr
LDAP_BINDDN=cn=svc-docsearch,ou=services,dc=domaine,dc=gouv,dc=fr
LDAP_PASS=changeme
ADMIN_GROUP=docsearch-admins
ADMIN_AUTH_DISABLED=false
DEV_USER=

# ── Paramètres opérationnels (voir README docsearch-ingestion) ─
WATCHER_POLL_INTERVAL=10
ARCHIVE_MAX_FILES=5000
ARCHIVE_MAX_TOTAL_SIZE_MB=1000
ARCHIVE_MAX_DEPTH=1
WORKER_BATCH_SIZE=200
WORKER_FLUSH_INTERVAL=10
FILETYPE_CONFIG_CACHE_TTL=10
RUNTIME_CONFIG_CACHE_TTL=10
PATHFILTER_CACHE_TTL=10
SOURCES_CONFIG_CACHE_TTL=10

# ── Permissions volumes ───────────────────────────────────────
# UID propriétaire de SOURCES_ROOT sur l'hôte (id -u) — doit être
# identique sur les 3 machines d'ingestion (même utilisateur, ou au
# moins même UID numérique, pour un partage réseau cohérent).
DOCKER_UID=1000
